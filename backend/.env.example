# Backend environment variables (production-ready example)
# Copy to `backend/.env` for local development. In production set these in Vercel.

# Use a pooled Neon/Postgres URL. Example pooled URL:
# postgresql://user:password@host-pooler.neon.tech/wishlist?sslmode=require
DATABASE_URL=postgresql://user:password@host-pooler.neon.tech/wishlist?sslmode=require

# JWT signing secret (HS256). Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=<generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))">

# OAuth credentials (fill in in Vercel or backend/.env)
# Redirect URI (exact): https://wishlist.vercel.app/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://zairo12.github.io/wishlist/,https://zairo12.github.io

# Public frontend URL used by the backend for redirects
FRONTEND_URL=https://zairo12.github.io/wishlist/

# Node environment
NODE_ENV=production
# Database
DATABASE_URL=postgresql://user:password@host:5432/wishlist_db

# JWT
JWT_SECRET=change-me-in-production-min-32-chars-random

# Frontend URL (GitHub Pages)
FRONTEND_URL=https://your-username.github.io/wishlist

# CORS allowed origins (comma separated)
ALLOWED_ORIGINS=https://your-username.github.io

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-backend.vercel.app/api/auth/callback?provider=google

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://your-backend.vercel.app/api/auth/callback?provider=github

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://your-backend.vercel.app/api/auth/callback?provider=microsoft
