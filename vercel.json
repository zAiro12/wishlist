{
  "version": 2,
  "buildCommand": "cd backend && npm ci && npx prisma generate && npm run build",
  "outputDirectory": "backend/dist",
  "functions": {
    "backend/api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/api/$1" }
  ]
}
