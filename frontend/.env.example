# Frontend environment variables (used at build time)
# Copy this file to `.env.local` during local dev or set repository Variables for CI builds.

# Base URL of the backend API (no trailing slash). Production value for GitHub Pages build:
VITE_API_URL=https://wishlist.vercel.app

# Vite base path (set to "/wishlist/" when deploying to GitHub Pages under a path)
VITE_BASE_URL=/wishlist/

# Optional: analytics or feature flags
VITE_SENTRY_DSN=
VITE_ENABLE_CHAT=false
# URL of the deployed Vercel backend (no trailing slash)
VITE_API_URL=https://your-backend.vercel.app

# Base path for GitHub Pages deployment – must match the repository name
# e.g. if hosted at https://username.github.io/wishlist/ use /wishlist/
# Leave as / for a custom domain or local dev
VITE_BASE_URL=/
